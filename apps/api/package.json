{
  "name": "@workwork/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "prisma migrate resolve --rolled-back 20251203_progress_entry_and_quarterly --schema=./prisma/schema.prisma || true && prisma migrate resolve --rolled-back 20260416_add_company_data --schema=./prisma/schema.prisma || true && prisma migrate resolve --rolled-back 20260417_add_openai_file_id --schema=./prisma/schema.prisma || true && prisma migrate deploy --schema=./prisma/schema.prisma || echo 'WARN: migrate deploy failed, continuing...' && node dist/main.js",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "3.10.1",
    "mammoth": "1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "2.4.5",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
