// ── 주기알람 (inspection_mgmt 기본형 연동) ──
model PeriodicAlarm {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  manualId      String?
  manual        WorkManual? @relation(fields: [manualId], references: [id])
  title         String
  description   String?
  cronExpression String?
  intervalDays  Int       @default(0)
  nextRunAt     DateTime?
  lastRunAt     DateTime?
