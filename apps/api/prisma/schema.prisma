// Prisma schema for initial OKR/Initiative/Worklog and Org

generator client {
  provider = "prisma-client-js"
}

model UserGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String?
  kind        GoalKind @default(QUALITATIVE)
  metric      String?
  target      Float?
  unit        String?
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  initiatives Initiative[]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CEO
  EXEC
  MANAGER
  INDIVIDUAL
  EXTERNAL
  GUARD
}

enum UserStatus {
  PENDING
  ACTIVE
}

enum ObjectiveStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum InitiativeState {
  PLANNED
  ACTIVE
  BLOCKED
  DONE
  CANCELLED
}

enum InitiativeType {
  PROJECT
  OPERATIONAL
}

enum Cadence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum KeyResultType {
  PROJECT
  OPERATIONAL
}

enum ThresholdDirection {
  AT_LEAST
  AT_MOST
}

enum Pillar {
  Q
  C
  D
  DEV
  P
}

model OrgUnit {
  id        String    @id @default(cuid())
  name      String
  type      String
  parentId  String?
  parent    OrgUnit?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[] @relation("OrgHierarchy")
  managerId String?
  manager   User?     @relation("OrgManager", fields: [managerId], references: [id])
  users     User[]
  objectives Objective[]
  processTemplates ProcessTemplate[]
  worklogTeamDailyEvals WorklogTeamDailyEval[]
  weeklyReports WeeklyReport[] @relation("WeeklyReportOrg")
  keyInitiatives KeyInitiative[]
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  teamsUpn   String?  @unique
  entraTenantId String?
  entraOid    String?  @unique
  name       String
  employeeNo String?  // 사번 (CAMS 입출입 기록 매칭용)
  role       Role
  status     UserStatus @default(ACTIVE)
  activatedAt DateTime?
  orgUnitId  String?
  orgUnit    OrgUnit? @relation(fields: [orgUnitId], references: [id])
  objectives Objective[] @relation("ObjectiveOwner")
  initiatives Initiative[] @relation("InitiativeOwner")
  managedUnits OrgUnit[] @relation("OrgManager")
  keyResultsOwned KeyResult[] @relation("KeyResultOwner")
  worklogsCreated Worklog[] @relation("WorklogCreator")
  approvalRequestsRequested ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalRequestsToApprove ApprovalRequest[] @relation("ApprovalApprover")
  approvalStepsToApprove ApprovalStep[] @relation("ApprovalStepApprover")
  shares Share[]
  feedbacksAuthored Feedback[]
  worklogTeamDailyEvals WorklogTeamDailyEval[]
  helpTicketsRequested HelpTicket[] @relation("HelpRequester")
  helpTicketsAssigned HelpTicket[] @relation("HelpAssignee")
  delegationsMade Delegation[] @relation("Delegator")
  delegationsReceived Delegation[] @relation("Delegatee")
  notifications Notification[]
  passwordHash String?
  checklistTicks ChecklistTick[]
  userGoals UserGoal[]
  progressEntries ProgressEntry[]
  keyResultAssignments KeyResultAssignment[]
  carDispatchRequestsRequested CarDispatchRequest[] @relation("CarDispatchRequester")
  carDispatchRequestsToApprove CarDispatchRequest[] @relation("CarDispatchApprover")
  logisticsRequestsMade        LogisticsDispatchRequest[] @relation("LogisticsRequester")
  logisticsRequestsToApprove   LogisticsDispatchRequest[] @relation("LogisticsApprover")
  attendanceRequests AttendanceRequest[]
  businessTripRequestsMade BusinessTripRequest[] @relation("TripRequester")
  businessTripRequestsToApprove BusinessTripRequest[] @relation("TripApprover")
  processTemplatesOwned ProcessTemplate[] @relation("ProcessTemplateOwner")
  processTemplatesCreated ProcessTemplate[] @relation("ProcessTemplateCreatedBy")
  processTemplatesUpdated ProcessTemplate[] @relation("ProcessTemplateUpdatedBy")
  processInstancesStarted ProcessInstance[] @relation("ProcessInstanceStartedBy")
  processInstancesModified ProcessInstance[] @relation("ProcessInstanceModifiedBy")
  processStopEvents ProcessStopEvent[] @relation("ProcessStop_on_User")

  workManuals WorkManual[]
  manualReviews WorkManual[] @relation("ManualReviewer")
  weeklyReports WeeklyReport[] @relation("WeeklyReportAuthor")
  knowledgeBases KnowledgeBase[]
  schedules Schedule[]
  periodicAlarms PeriodicAlarm[]
  workSkillFiles WorkSkillFile[]
  meetingMinutes MeetingMinutes[] @relation("MeetingMinutesCreatedBy")
  meetingSummaryEdits MeetingSummaryEdit[] @relation("MeetingSummaryEditor")
  plannerTaskCache PlannerTaskCache[]
  companyDataUploads CompanyData[] @relation("CompanyDataUploader")
  companyDataChats CompanyDataChat[] @relation("CompanyDataChatUser")
  likes Like[]
  instructionsAssigned WorklogInstruction[] @relation("InstructionAssignee")
  instructionsGiven    WorklogInstruction[] @relation("InstructionAssigner")
  worklogSupplements   WorklogSupplement[]  @relation("WorklogSupplementAuthor")

  keyInitiativesAssigned KeyInitiative[] @relation("KeyInitiativeAssignee")
  keyInitiativesCreated  KeyInitiative[] @relation("KeyInitiativeCreator")
  keyInitiativeProgress  KeyInitiativeProgress[]
  documentViewLogs       DocumentViewLog[]

  teamsPhotoBytes Bytes?
  teamsPhotoContentType String?
  teamsPhotoUpdatedAt DateTime?

  graphAccessToken  String?  @db.Text
  graphRefreshToken String?  @db.Text
  graphTokenExpiry  DateTime?
}

model Objective {
  id          String    @id @default(cuid())
  title       String
  description String?
  orgUnitId   String
  orgUnit     OrgUnit   @relation(fields: [orgUnitId], references: [id])
  ownerId     String
  owner       User      @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  parentId    String?
  parent      Objective? @relation("ObjectiveTree", fields: [parentId], references: [id])
  children    Objective[] @relation("ObjectiveTree")
  status      ObjectiveStatus @default(DRAFT)
  periodStart DateTime
  periodEnd   DateTime
  alignsToKrId String?
  alignsToKr   KeyResult? @relation("ObjectiveAlignedToKR", fields: [alignsToKrId], references: [id])
  keyResults  KeyResult[]
  pillar      Pillar?
  keyInitiatives KeyInitiative[] @relation("KeyInitiativeAlignment")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KeyResult {
  id           String    @id @default(cuid())
  objectiveId  String
  objective    Objective @relation(fields: [objectiveId], references: [id])
  title        String
  metric       String
  target       Float
  unit         String
  weight       Float     @default(1)
  ownerId      String
  owner        User      @relation("KeyResultOwner", fields: [ownerId], references: [id])
  initiatives  Initiative[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  type         KeyResultType @default(PROJECT)
  alignedObjectives Objective[] @relation("ObjectiveAlignedToKR")
  pillar       Pillar?
  baseline     Float?
  year25Target Float?
  cadence      Cadence?
  progressEntries ProgressEntry[]
  direction    ThresholdDirection?
  assignments  KeyResultAssignment[]
  analysis25   String?
}

model KeyResultAssignment {
  id          String   @id @default(cuid())
  keyResultId String
  keyResult   KeyResult @relation(fields: [keyResultId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  role        String?
  createdAt   DateTime @default(now())
}

model Initiative {
  id            String   @id @default(cuid())
  keyResultId   String
  keyResult     KeyResult @relation(fields: [keyResultId], references: [id])
  title         String
  description   String?
  state         InitiativeState @default(PLANNED)
  type          InitiativeType  @default(PROJECT)
  ownerId       String
  owner         User     @relation("InitiativeOwner", fields: [ownerId], references: [id])
  priority      Int      @default(3)
  slaMinutes    Int?
  dueAt         DateTime?
  startAt       DateTime?
  endAt         DateTime?
  cadence       Cadence?
  cadenceAnchor String?
  worklogs      Worklog[]
  checklistItems ChecklistItem[]
  userGoalId    String?
  userGoal      UserGoal? @relation(fields: [userGoalId], references: [id])
  parentId      String?
  parent        Initiative? @relation("InitiativeTree", fields: [parentId], references: [id])
  children      Initiative[] @relation("InitiativeTree")
  delegationsAsChild Delegation[] @relation("DelegationChildInitiative")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  progressEntries ProgressEntry[]
  processInstances ProcessInstance[]
  processTaskInstances ProcessTaskInstance[]
}

model Worklog {
  id                    String   @id @default(cuid())
  initiativeId          String
  initiative            Initiative @relation(fields: [initiativeId], references: [id])
  date                  DateTime  @default(now())
  progressPct           Int       @default(0)
  timeSpentMinutes      Int       @default(0)
  blockerCode           String?
  note                  String?
  structuredData        Json?
  createdById           String
  createdBy             User      @relation("WorklogCreator", fields: [createdById], references: [id])
  attachments           Json?
  tags                  Json?
  createdAt             DateTime  @default(now())
  urgent                Boolean   @default(false)
  keywords              String?
  progressEntries       ProgressEntry[]
  visibility            WorklogVisibility @default(ALL)
  processTaskInstanceId String?
  processTaskInstance   ProcessTaskInstance? @relation("TaskWorklogs", fields: [processTaskInstanceId], references: [id])
  supplements           WorklogSupplement[]

  @@index([date])
  @@index([createdAt])
  @@index([createdById, date])
  @@index([createdById, createdAt])
  @@index([visibility, date])
}

model WorklogSupplement {
  id          String   @id @default(cuid())
  worklogId   String
  worklog     Worklog  @relation(fields: [worklogId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("WorklogSupplementAuthor", fields: [userId], references: [id])
  content     String?
  attachments Json?
  createdAt   DateTime @default(now())

  @@index([worklogId])
}

enum WeeklyReportStatus {
  DRAFT
  CONFIRMED
}

model WeeklyReport {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation("WeeklyReportAuthor", fields: [userId], references: [id])
  orgUnitId   String?
  orgUnit     OrgUnit?            @relation("WeeklyReportOrg", fields: [orgUnitId], references: [id])
  weekStart   DateTime
  sections    Json?
  status      WeeklyReportStatus  @default(DRAFT)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([userId, weekStart])
  @@index([orgUnitId, weekStart])
  @@index([weekStart])
}

enum ManualStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
}

model WorkManual {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  title           String
  content         String?
  authorName      String       @default("")
  authorTeamName  String       @default("")
  department      String       @default("")
  baseType        String       @default("")
  options         Json?
  phaseData       Json?
  currentPhase    Int          @default(1)
  version         Int          @default(1)
  versionUpAt     DateTime     @default(now())
  status          ManualStatus @default(DRAFT)
  reviewerId      String?
  reviewer        User?        @relation("ManualReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  reviewComment   String?
  qualityScore    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([updatedAt])
  @@index([versionUpAt])
  @@index([status])
  @@index([reviewerId])
  @@index([baseType])

  knowledgeBases KnowledgeBase[]
  schedules Schedule[]
  periodicAlarms PeriodicAlarm[]
  workSkillFiles WorkSkillFile[]
}

model Event {
  id          String   @id @default(cuid())
  subjectType String
  subjectId   String
  activity    String
  ts          DateTime @default(now())
  userId      String?
  assetId     String?
  attrs       Json?
  idx         Int      @default(0)
}

model Asset {
  id     String @id @default(cuid())
  name   String
  type   String
  code   String  @unique
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ShareScope {
  READ
  COMMENT
}

enum FeedbackType {
  GENERAL
  RUBRIC
  INSTRUCTION
}

enum WorklogInstructionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum HelpStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum DelegationStatus {
  PENDING
  ACCEPTED
  REJECTED
  ACTIVE
  BLOCKED
  DONE
}

enum WorklogVisibility {
  ALL
  MANAGER_PLUS
  EXEC_PLUS
  CEO_ONLY
}

enum WorklogEvalStatus {
  BLUE
  GREEN
  YELLOW
  RED
}

enum GoalKind {
  QUALITATIVE
  QUANTITATIVE
}

enum DispatchStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceType {
  OT
  VACATION
  EARLY_LEAVE
  FLEXIBLE
  HOLIDAY_WORK
  HOLIDAY_REST
  PUBLIC_DUTY
  PARENTAL_LEAVE
}

enum ProcessType {
  RECURRING
  PROJECT
}

enum ProcessVisibility {
  PUBLIC
  ORG_UNIT
  PRIVATE
}

enum TaskType {
  COOPERATION
  WORKLOG
  APPROVAL
  TASK
}

enum AssigneeType {
  USER
  ORG_UNIT
  ROLE
}

enum ApprovalRouteType {
  ORG_CHART
  ROLE_BASED
  CUSTOM_USERS
}

model ApprovalRequest {
  id             String          @id @default(cuid())
  subjectType    String
  subjectId      String
  status         ApprovalStatus  @default(PENDING)
  requestedById  String
  requestedBy    User            @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approverId     String
  approver       User            @relation("ApprovalApprover", fields: [approverId], references: [id])
  dueAt          DateTime?
  tags           Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  steps          ApprovalStep[]
}

model ApprovalStep {
  id         String          @id @default(cuid())
  requestId  String
  request    ApprovalRequest @relation(fields: [requestId], references: [id])
  stepNo     Int
  approverId String
  approver   User            @relation("ApprovalStepApprover", fields: [approverId], references: [id])
  status     ApprovalStatus  @default(PENDING)
  comment    String?
  actedAt    DateTime?
}

model Share {
  id          String     @id @default(cuid())
  subjectType String
  subjectId   String
  watcherId   String
  watcher     User       @relation(fields: [watcherId], references: [id])
  scope       ShareScope @default(READ)
  createdAt   DateTime   @default(now())
}

model Feedback {
  id          String        @id @default(cuid())
  subjectType String
  subjectId   String
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  type        FeedbackType  @default(GENERAL)
  content     String
  rating      Int?
  actionRequired Boolean    @default(false)
  createdAt   DateTime      @default(now())
}

// A lightweight task created from a worklog comment of type INSTRUCTION.
// Assigner and assignee are users; the assignee can later "complete" the
// instruction by writing a worklog and linking it via completedWorklogId.
model WorklogInstruction {
  id                 String                   @id @default(cuid())
  sourceFeedbackId   String                   @unique
  sourceWorklogId    String
  assignerId         String
  assigner           User                     @relation("InstructionAssigner", fields: [assignerId], references: [id])
  assigneeId         String
  assignee           User                     @relation("InstructionAssignee", fields: [assigneeId], references: [id])
  title              String
  description        String?
  dueDate            DateTime?
  status             WorklogInstructionStatus @default(OPEN)
  completedWorklogId String?
  completedAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([assigneeId, status])
  @@index([sourceWorklogId])
}

model Like {
  id          String   @id @default(cuid())
  subjectType String
  subjectId   String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([subjectType, subjectId, userId])
  @@index([subjectType, subjectId])
}

model WorklogTeamDailyEval {
  id          String           @id @default(cuid())
  ymd         String
  orgUnitId   String
  orgUnit     OrgUnit          @relation(fields: [orgUnitId], references: [id])
  evaluatorId String
  evaluator   User             @relation(fields: [evaluatorId], references: [id])
  status      WorklogEvalStatus
  comment     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([ymd, orgUnitId, evaluatorId])
  @@index([ymd])
  @@index([orgUnitId, ymd])
  @@index([evaluatorId, ymd])
}

model HelpTicket {
  id           String      @id @default(cuid())
  category     String
  queue        String?
  requesterId  String
  requester    User        @relation("HelpRequester", fields: [requesterId], references: [id])
  assigneeId   String?
  assignee     User?       @relation("HelpAssignee", fields: [assigneeId], references: [id])
  status       HelpStatus  @default(OPEN)
  dueAt        DateTime?
  slaMinutes   Int?
  tags         Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  resolvedAt   DateTime?
}

model Delegation {
  id                 String            @id @default(cuid())
  parentType         String
  parentId           String
  childInitiativeId  String
  childInitiative    Initiative        @relation("DelegationChildInitiative", fields: [childInitiativeId], references: [id])
  delegatorId        String
  delegator          User              @relation("Delegator", fields: [delegatorId], references: [id])
  delegateeId        String
  delegatee          User              @relation("Delegatee", fields: [delegateeId], references: [id])
  status             DelegationStatus  @default(PENDING)
  dueAt              DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  acceptedAt         DateTime?
  rejectedAt         DateTime?
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  subjectType String
  subjectId   String
  payload     Json?
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model Upload {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String?
  contentType  String?
  size         Int
  data         Bytes
  createdAt    DateTime @default(now())
}

model ChecklistItem {
  id            String   @id @default(cuid())
  initiativeId  String
  initiative    Initiative @relation(fields: [initiativeId], references: [id])
  title         String
  order         Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  ticks         ChecklistTick[]
}

model ChecklistTick {
  id              String   @id @default(cuid())
  checklistItemId String
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  checkedAt       DateTime @default(now())
  actorId         String
  actor           User     @relation(fields: [actorId], references: [id])
}

model ProgressEntry {
  id            String    @id @default(cuid())
  worklogId     String?
  worklog       Worklog?  @relation(fields: [worklogId], references: [id])
  actorId       String
  actor         User      @relation(fields: [actorId], references: [id])
  keyResultId   String?
  keyResult     KeyResult? @relation(fields: [keyResultId], references: [id])
  initiativeId  String?
  initiative    Initiative? @relation(fields: [initiativeId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  krValue       Float?
  initiativeDone Boolean?
  note          String?
  createdAt     DateTime @default(now())
}

model Car {
  id        String   @id @default(cuid())
  name      String
  type      String?
  plateNo   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dispatchRequests CarDispatchRequest[]
}

model CarDispatchRequest {
  id           String         @id @default(cuid())
  carId        String
  car          Car            @relation(fields: [carId], references: [id])
  requesterId  String
  requester    User           @relation("CarDispatchRequester", fields: [requesterId], references: [id])
  approverId   String
  approver     User           @relation("CarDispatchApprover", fields: [approverId], references: [id])
  coRiders     String?
  startAt      DateTime
  endAt        DateTime
  destination  String
  purpose      String
  driverName   String?        // 경비실 긴급 등록 시 운전자명(시스템 계정이 아닌 경우)
  guardCreated Boolean        @default(false) // 경비실 직접(긴급) 등록 여부

  // 선점자와 협의한 추가/교환 배차
  coUse              Boolean   @default(false) // 협의(추가/교환) 배차 여부
  negotiatedWithId   String?   // 선점자(협의 상대) user id
  negotiationStatus  String?   // REQUESTED | AGREED | DECLINED
  negotiationNote    String?   // 협의 메모 (예: 남는 시간 사용 / 차량 교환)
  conflictDispatchId String?   // 협의 대상이 된 선점 배차 id

  dispatchType String         @default("CORPORATE") // CORPORATE | LOGISTICS
  cargoDetails String?        // 화물 내용 (물류 전용)
  status       DispatchStatus @default(PENDING)

  // 경비실 입·출차 관리
  checkoutAt   DateTime?      // 출차 확인 시각 (경비)
  checkinAt    DateTime?      // 입차 확인 시각 (경비)
  checkedOutById String?      // 출차 확인한 사용자(경비) id
  checkedInById  String?      // 입차 확인한 사용자(경비) id

  // 주행거리 (경비실 입력 = 공식 확인값)
  odometerStart Int?          // 출발 적산거리(km) - 경비 확인
  odometerEnd   Int?          // 복귀 적산거리(km) - 경비 확인
  distanceKm    Int?          // 주행거리(km) = end - start

  // 차량 사용 전후 등록 (운전자)
  statusPhotos  Json?         // (구) 차량 상태 사진 URL 배열 — 하위호환
  odometerPhotos Json?        // (구) 계기판 사진 URL 배열 — 하위호환
  statusPhotosBefore   Json?  // 차량 상태 사진(사용 전)
  statusPhotosAfter    Json?  // 차량 상태 사진(사용 후)
  odometerPhotosBefore Json?  // 계기판 사진(사용 전)
  odometerPhotosAfter  Json?  // 계기판 사진(사용 후)
  odometerBeforeOcr Int?      // 사용 전 인식 적산거리(km, 운전자 사진 OCR)
  odometerAfterOcr  Int?      // 사용 후 인식 적산거리(km, 운전자 사진 OCR)
  usageNote     String?       // 특이사항
  usageRegisteredAt DateTime? // 사용 전후 등록 시각
  usageRegisteredById String? // 등록한 운전자 id

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model LogisticsDispatchRequest {
  id               String         @id @default(cuid())
  requesterId      String
  requester        User           @relation("LogisticsRequester", fields: [requesterId], references: [id])
  approverId       String
  approver         User           @relation("LogisticsApprover", fields: [approverId], references: [id])
  vehicleType      String
  loadingPlace     String
  loadingAt        DateTime
  loadingContact   String
  loadingPhone     String
  unloadingPlace   String
  unloadingAt      DateTime
  unloadingContact String
  unloadingPhone   String
  cargoDetails     String?
  status           DispatchStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model BusinessTripRequest {
  id            String   @id @default(cuid())
  requesterId   String
  requester     User     @relation("TripRequester", fields: [requesterId], references: [id])
  approverId    String
  approver      User     @relation("TripApprover", fields: [approverId], references: [id])
  approvalLine  Json?    // ordered array of approver userIds
  destination   String
  purpose       String
  departureAt   DateTime
  returnAt      DateTime
  transportation String?  // 자가용/대중교통/항공/회사차량/기타
  accommodation Boolean  @default(false)
  notes         String?
  status        String   @default("PENDING") // PENDING/APPROVED/REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AttendanceRequest {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  type        AttendanceType
  date        DateTime
  // 기간 신청(휴가/육아휴직 등)의 종료일. null이면 date 하루짜리 신청.
  // 시작일=date, 종료일=endDate 로 연속 기간을 한 건(단일 결재)으로 처리한다.
  endDate     DateTime?
  startAt     DateTime?
  endAt       DateTime?
  reason      String?
  attachments Json?          // Array of { url, name, size?, contentType? }
  status      String         @default("PENDING")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProcessTemplate {
  id                         String             @id @default(cuid())
  title                      String
  description                String?
  type                       ProcessType        @default(PROJECT)
  ownerId                    String
  owner                      User               @relation("ProcessTemplateOwner", fields: [ownerId], references: [id])
  createdById                String
  createdBy                  User               @relation("ProcessTemplateCreatedBy", fields: [createdById], references: [id])
  updatedById                String
  updatedBy                  User               @relation("ProcessTemplateUpdatedBy", fields: [updatedById], references: [id])
  visibility                 ProcessVisibility  @default(PUBLIC)
  orgUnitId                  String?
  orgUnit                    OrgUnit?           @relation(fields: [orgUnitId], references: [id])
  recurrenceType             String?
  recurrenceDetail           String?
  sourceManualId             String? // 이 템플릿을 생성한 업무 매뉴얼 (WorkManual.id, 느슨한 연결)
  scheduleEnabled            Boolean            @default(false)
  scheduleNextRunAt          DateTime?
  scheduleLastRunAt          DateTime?
  bpmnJson                   Json?
  resultInputRequired        Boolean            @default(false)
  expectedDurationDays       Int?
  expectedCompletionCriteria String?
  allowExtendDeadline        Boolean            @default(true)
  status                     String             @default("ACTIVE")
  official                   Boolean            @default(false)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  tasks                      ProcessTaskTemplate[]
  instances                  ProcessInstance[]
}

model ProcessTaskTemplate {
  id                     String            @id @default(cuid())
  processTemplateId      String
  processTemplate        ProcessTemplate   @relation(fields: [processTemplateId], references: [id])
  name                   String
  description            String?
  assigneeHint           String?
  taskType               TaskType          @default(TASK)
  orderHint              Int               @default(0)
  stageLabel             String?
  predecessorIds         String?           // comma-separated template IDs
  predecessorMode        String?           // 'ALL'(default) or 'ANY' (for XOR joins)
  xorGroupKey            String?
  xorCondition           String?
  assigneeType           AssigneeType?
  assigneeUserId         String?
  assigneeOrgUnitId      String?
  assigneeRoleCode       String?
  cooperationTargetType  AssigneeType?
  cooperationTargetUserId String?
  cooperationTargetOrgUnitId String?
  cooperationTargetRoleCode String?
  expectedOutput         String?
  emailToTemplate        String?
  emailCcTemplate        String?
  emailSubjectTemplate   String?
  emailBodyTemplate      String?
  worklogTemplateHint    String?
  linkToKpiType          String?
  approvalRouteType      ApprovalRouteType?
  approvalRoleCodes      String?           // comma-separated role codes
  approvalUserIds        String?           // comma-separated user IDs
  isFinalApproval        Boolean           @default(false)
  deadlineOffsetDays     Int?
  slaHours               Int?
  allowDelayReasonRequired Boolean        @default(false)
  loopBackTargetId       String?           // 반려 시 돌아갈 태스크 템플릿 ID (루프백)
  loopBackCondition      String?           // 루프백 조건 (예: last.approval.status == 'REJECTED')
  maxLoopCount           Int?              // 최대 루프 횟수 (기본 3, 무한루프 방지)
  taskInstances          ProcessTaskInstance[]
}

model ProcessInstance {
  id              String            @id @default(cuid())
  templateId      String
  template        ProcessTemplate   @relation(fields: [templateId], references: [id])
  title           String
  startedById     String
  startedBy       User             @relation("ProcessInstanceStartedBy", fields: [startedById], references: [id])
  status          String           @default("ACTIVE")
  version         Int              @default(1)
  startAt         DateTime         @default(now())
  endAt           DateTime?
  expectedEndAt   DateTime?
  itemCode        String?          // 품번 등 기준 정보 코드
  moldCode        String?          // 금형 번호
  carModelCode    String?          // 차종 코드
  supplierCode    String?          // 협력사 코드
  initiativeId    String?
  initiative      Initiative?      @relation(fields: [initiativeId], references: [id])
  modifiedById    String?
  modifiedBy      User?            @relation("ProcessInstanceModifiedBy", fields: [modifiedById], references: [id])
  modifiedAt      DateTime?
  modificationReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tasks           ProcessTaskInstance[]
  stopEvents      ProcessStopEvent[] @relation("ProcessStop_on_Instance")
}

model ProcessTaskInstance {
  id                String              @id @default(cuid())
  instanceId        String
  instance          ProcessInstance     @relation(fields: [instanceId], references: [id])
  taskTemplateId    String
  taskTemplate      ProcessTaskTemplate @relation(fields: [taskTemplateId], references: [id])
  name              String
  stageLabel        String?
  taskType          TaskType
  status            String             @default("NOT_STARTED")
  plannedStartAt    DateTime?
  plannedEndAt      DateTime?
  actualStartAt     DateTime?
  actualEndAt       DateTime?
  deadlineAt        DateTime?
  worklogId         String?
  cooperationId     String?
  approvalRequestId String?
  emailTo           String?
  emailCc           String?
  emailSubject      String?
  emailBody         String?
  assigneeId        String?
  decidedById       String?
  decisionReason    String?
  loopCount         Int                @default(0)
  initiativeId      String?
  initiative        Initiative?        @relation(fields: [initiativeId], references: [id])
  worklogs          Worklog[]          @relation("TaskWorklogs")
  deadlineAlerts    ProcessDeadlineAlert[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum StopType {
  SUSPENDED
  ABORTED
}

model ProcessStopEvent {
  id               String         @id @default(cuid())
  processInstanceId String
  processInstance  ProcessInstance @relation("ProcessStop_on_Instance", fields: [processInstanceId], references: [id])
  stoppedById      String
  stoppedBy        User           @relation("ProcessStop_on_User", fields: [stoppedById], references: [id])
  stopType         StopType
  reason           String
  stoppedAt        DateTime       @default(now())
}

model ProcessDeadlineAlert {
  id              String              @id @default(cuid())
