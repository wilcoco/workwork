  @@index([userId])
  @@index([manualId])
  @@index([status])
}

/// Every time a user manually edits the AI-generated summary, we store a
/// before/after snapshot here. These examples are later injected into the
/// summarise prompt as few-shot references so the model gradually learns
/// the team's preferred style and corrections.
model MeetingSummaryEdit {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      MeetingMinutes @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  original     String   @db.Text
  edited       String   @db.Text
  editedById   String?
  editedBy     User?    @relation("MeetingSummaryEditor", fields: [editedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([meetingId])
  @@index([createdAt])
}

model MeetingMinutes {
  id            String   @id @default(cuid())
  title         String
  date          DateTime @default(now())
  participants  Json?    // string[] of participant names/ids
  audioUploadId String?  // reference to Upload.id for the audio file
  audioChunks   Json?    // Array of { uploadId, order, duration } for chunked audio
  transcript    String?  @db.Text
  summary       String?  @db.Text
  actionItems   Json?    // Array of { text, assignee?, dueDate? }
  attachments   Json?    // Array of { url, name, size?, contentType? }
  status        String   @default("draft") // draft | recording | transcribing | summarized | finalized
  duration      Int?     // total duration in seconds
  createdById   String
  createdBy     User     @relation("MeetingMinutesCreatedBy", fields: [createdById], references: [id])
  summaryEdits  MeetingSummaryEdit[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdById])
  @@index([date])
  @@index([status])
}

model PlannerTaskCache {
  id              String   @id @default(cuid())
  graphTaskId     String
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  title           String
  dueDateTime     DateTime?
  percentComplete Int      @default(0)
  priority        Int      @default(5)
  planName        String?
  groupName       String?
  syncedAt        DateTime @default(now())

  @@unique([graphTaskId, userId])
  @@index([userId])
  @@index([dueDateTime])
  @@index([percentComplete])
}

model CompanyData {
  id            String   @id @default(cuid())
  title         String
  description   String?
  fileUrl       String
  fileName      String
  content       String?  @db.Text
  openaiFileId  String?
  uploadedById  String
  uploadedBy    User     @relation("CompanyDataUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([uploadedById])
}

model CompanyDataChat {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  dataIds   String[]
  /// Originating page/feature so the same table can power multiple
  /// distinct chat lists. Examples: 'company-data', 'worklog-analysis'.
  /// Nullable for legacy rows recorded before this column existed.
  source    String?
  userId    String
  user      User     @relation("CompanyDataChatUser", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([source])
